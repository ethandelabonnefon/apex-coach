# Anthropic — Claude Sonnet 4 (génération de programmes, coach IA, vision)
ANTHROPIC_API_KEY=sk-ant-...

# LibreLink Up — lecture FreeStyle Libre 2 en temps réel
# Utilise tes credentials de l'app LibreLinkUp (même compte que ta/ton soignant.e partage).
# Si non défini : l'app fonctionne en mode manuel (logs glycémie à la main).
LIBRELINK_EMAIL=
LIBRELINK_PASSWORD=
# Optionnel — 4.16.0 est le default testé en avril 2026.
# À bumper (4.17.0, 4.18.0...) uniquement si l'API Abbott renvoie 403/430.
LIBRELINK_CLIENT_VERSION=4.16.0

# ─── Push notifications (alertes hypo / hyper) ────────────────────────────
# Génère les clés une seule fois avec : npx web-push generate-vapid-keys --json
# Puis colle les 2 valeurs ci-dessous (la publique est préfixée NEXT_PUBLIC_
# pour être accessible côté client ; la privée reste serveur-only).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Identifiant VAPID (mailto ou URL). Requis par la spec Web Push.
VAPID_SUBJECT=mailto:ethandelabonnefon@gmail.com

# Secret partagé entre Vercel Cron et l'endpoint /api/cron/glucose-check.
# Mets une chaîne aléatoire (`openssl rand -hex 24` par exemple).
# Vercel Cron passera automatiquement ce secret dans l'Authorization header.
CRON_SECRET=

# ─── Vercel KV (Redis) — stockage des subscriptions push ──────────────────
# Ces variables sont AUTOMATIQUEMENT injectées par Vercel quand tu lies un
# KV store au projet (Storage → Create Database → KV → Connect Project).
# Tu n'as PAS à les remplir à la main.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
