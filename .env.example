# Anthropic — Claude Sonnet 4 (génération de programmes, coach IA, vision)
ANTHROPIC_API_KEY=sk-ant-...

# LibreLink Up — lecture FreeStyle Libre 2 en temps réel
# Utilise tes credentials de l'app LibreLinkUp (même compte que ta/ton soignant.e partage).
# Si non défini : l'app fonctionne en mode manuel (logs glycémie à la main).
LIBRELINK_EMAIL=
LIBRELINK_PASSWORD=
# Optionnel — 4.16.0 est le default testé en avril 2026.
# À bumper (4.17.0, 4.18.0...) uniquement si l'API Abbott renvoie 403/430.
LIBRELINK_CLIENT_VERSION=4.16.0
